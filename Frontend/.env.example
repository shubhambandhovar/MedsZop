# Demo Account Credentials (for testing only)
# These should be set in your actual .env.local file
# DO NOT COMMIT .env.local or actual credentials to git

# Admin Demo Account
VITE_DEMO_ADMIN_EMAIL=admin@medszop.com
VITE_DEMO_ADMIN_PASS=demo-admin

# Customer Demo Account
VITE_DEMO_CUSTOMER_EMAIL=customer@medszop.com
VITE_DEMO_CUSTOMER_PASS=demo-customer

# Pharmacy Demo Account
VITE_DEMO_PHARMACY_EMAIL=pharmacy@medszop.com
VITE_DEMO_PHARMACY_PASS=demo-pharmacy

# Firebase Configuration (if using Firebase)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id

# Backend API URL
VITE_API_URL=http://localhost:5000/api
